# Application
NODE_ENV=development
PORT=3003

# Database (Processor DB - read access)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/video_processing_processor

# JWT (same secret as MS-Auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# MinIO (for generating download URLs)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_PROCESSED=processed-zips

# CORS
CORS_ORIGIN=http://localhost:3000

# WebSocket
WS_PORT=3003
